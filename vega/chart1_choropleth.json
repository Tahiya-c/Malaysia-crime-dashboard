{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "config": {
    "view": {"stroke": null}, "font": "Inter",
    "axis": {
      "labelFont": "Inter", "titleFont": "Inter",
      "labelColor": "#71717a", "titleColor": "#3f3f46",
      "domainColor": "#d4d4d8", "tickColor": "#d4d4d8",
      "gridColor": "rgba(0,0,0,0.05)"
    },
    "legend": {"labelFont": "Inter", "titleFont": "Inter"},
    "title": {"font": "Inter", "subtitleFont": "Inter"}
  },
  "params": [
    {
      "name": "Year_selection", "value": 2023,
      "bind": {
        "input": "range", "min": 2016, "max": 2023,
        "step": 1, "name": "Year:  "
      }
    }
  ],
  "hconcat": [
    {
      "title": {
        "text": "Crime intensity across Malaysia",
        "subtitle": "Total reported crimes per state. Drag the slider to explore.",
        "fontSize": 15, "fontWeight": 600,
        "subtitleFontSize": 11, "subtitleColor": "#71717a",
        "anchor": "start", "offset": 10
      },
      "width": 700, "height": 500,
      "layer": [
        {
          "data": {
            "url": "data/geoBoundaries-MYS-ADM1.topojson",
            "format": {"type": "topojson", "feature": "MYSADM1gbOpen"}
          },
          "projection": {"type": "mercator"},
          "mark": {
            "type": "geoshape",
            "fill": "#f1f5f9",
            "stroke": "#cbd5e1",
            "strokeWidth": 0.8
          }
        },
        {
          "data": {"url": "data/state_year_total.csv"},
          "transform": [
            {"filter": "datum.year == Year_selection"},
            {
              "calculate": "datum.state === 'Melaka' ? 'Malacca' : datum.state",
              "as": "shapeName"
            },
            {
              "lookup": "shapeName",
              "from": {
                "data": {
                  "url": "data/geoBoundaries-MYS-ADM1.topojson",
                  "format": {"type": "topojson", "feature": "MYSADM1gbOpen"}
                },
                "key": "properties.shapeName",
                "fields": ["type", "geometry", "properties"]
              }
            }
          ],
          "projection": {"type": "mercator"},
          "mark": {"type": "geoshape", "stroke": "white", "strokeWidth": 0.9},
          "encoding": {
            "shape": {"field": "geometry", "type": "geojson"},
            "color": {
              "field": "crimes", "type": "quantitative",
              "scale": {
                "scheme": "cividis", "reverse": true,
                "type": "sqrt", "domain": [0, 32000], "clamp": true
              },
              "legend": {
                "title": "Reported crimes",
                "format": "~s",
                "orient": "bottom-left",
                "gradientLength": 130,
                "titleFontSize": 10, "labelFontSize": 9,
                "titleColor": "#71717a", "labelColor": "#71717a",
                "offset": 10
              }
            },
            "tooltip": [
              {"field": "state", "type": "nominal", "title": "State"},
              {"field": "crimes", "type": "quantitative", "title": "Crimes", "format": ","},
              {"field": "year", "type": "quantitative", "title": "Year"}
            ]
          }
        }
      ]
    },
    {
      "title": {
        "text": "States ranked",
        "subtitle": "Selected-year total crimes",
        "fontSize": 13, "fontWeight": 600,
        "subtitleFontSize": 10, "subtitleColor": "#71717a",
        "anchor": "start", "offset": 10
      },
      "width": 250, "height": 500,
      "data": {"url": "data/state_year_total.csv"},
      "transform": [{"filter": "datum.year == Year_selection"}],
      "layer": [
        {
          "mark": {"type": "bar", "cornerRadiusEnd": 3, "height": 18},
          "encoding": {
            "y": {
              "field": "state", "type": "nominal",
              "sort": {"field": "crimes", "order": "descending"},
              "axis": {
                "title": null, "labelFontSize": 10,
                "labelPadding": 4, "ticks": false, "domain": false
              }
            },
            "x": {
              "field": "crimes", "type": "quantitative",
              "axis": {
                "title": "Crimes", "format": "~s",
                "labelFontSize": 9, "tickCount": 3, "grid": true
              }
            },
            "color": {
              "field": "crimes", "type": "quantitative",
              "scale": {
                "scheme": "cividis", "reverse": true,
                "type": "sqrt", "domain": [0, 32000], "clamp": true
              },
              "legend": null
            },
            "tooltip": [
              {"field": "state", "type": "nominal", "title": "State"},
              {"field": "crimes", "type": "quantitative", "title": "Crimes", "format": ","}
            ]
          }
        },
        {
          "mark": {
            "type": "text", "align": "left",
            "dx": 4, "fontSize": 9, "color": "#71717a"
          },
          "encoding": {
            "y": {
              "field": "state", "type": "nominal",
              "sort": {"field": "crimes", "order": "descending"}
            },
            "x": {"field": "crimes", "type": "quantitative"},
            "text": {"field": "crimes", "type": "quantitative", "format": ",.0f"}
          }
        }
      ]
    }
  ]
}
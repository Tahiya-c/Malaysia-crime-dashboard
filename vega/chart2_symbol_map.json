{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "District proportional symbol map. Larger map, smaller transparent bubbles, dark labels, no borders on text.",
  "background": "transparent",
  "config": {
    "view": {
      "stroke": null
    },
    "font": "Inter",
    "title": {
      "font": "Inter",
      "subtitleFont": "Inter",
      "anchor": "start",
      "offset": 10
    },
    "legend": {
      "labelFont": "Inter",
      "titleFont": "Inter",
      "titleFontSize": 10,
      "labelFontSize": 9
    }
  },
  "title": {
    "text": "Where crime concentrates: district-level hotspots",
    "subtitle": "Each circle = one police district. Larger and darker = more crimes reported 2016\u20132023.",
    "fontSize": 15,
    "fontWeight": 600,
    "subtitleFontSize": 11,
    "subtitleColor": "#71717a"
  },
  "width": 1050,
  "height": 520,
  "params": [
    {
      "name": "metric",
      "value": "All crimes",
      "bind": {
        "input": "radio",
        "options": [
          "All crimes",
          "Property only",
          "Assault only"
        ],
        "name": "Show:  "
      }
    }
  ],
  "layer": [
    {
      "data": {
        "url": "data/geoBoundaries-MYS-ADM1.topojson",
        "format": {
          "type": "topojson",
          "feature": "MYSADM1gbOpen"
        }
      },
      "projection": {
        "type": "mercator",
        "scale": 2800,
        "center": [
          109.5,
          4.0
        ]
      },
      "mark": {
        "type": "geoshape",
        "fill": "#e8e4dd",
        "stroke": "#b8b2aa",
        "strokeWidth": 0.5
      }
    },
    {
      "data": {
        "url": "data/district_totals.csv"
      },
      "transform": [
        {
          "calculate": "metric === 'Property only' ? datum.total_property : metric === 'Assault only' ? datum.total_assault : datum.total_crimes",
          "as": "value"
        },
        {
          "filter": "datum.value > 0"
        },
        {
          "window": [
            {
              "op": "rank",
              "as": "vol_rank"
            }
          ],
          "sort": [
            {
              "field": "value",
              "order": "descending"
            }
          ]
        }
      ],
      "projection": {
        "type": "mercator",
        "scale": 2800,
        "center": [
          109.5,
          4.0
        ]
      },
      "mark": {
        "type": "circle",
        "stroke": null,
        "opacity": 0.38
      },
      "encoding": {
        "longitude": {
          "field": "lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "lat",
          "type": "quantitative"
        },
        "size": {
          "field": "value",
          "type": "quantitative",
          "scale": {
            "type": "sqrt",
            "range": [
              8,
              420
            ]
          },
          "legend": {
            "title": "Total cases",
            "format": "~s",
            "orient": "bottom-left",
            "gradientLength": 100,
            "offset": 10,
            "titleFontSize": 9,
            "labelFontSize": 9
          }
        },
        "color": {
          "field": "value",
          "type": "quantitative",
          "scale": {
            "scheme": "reds",
            "type": "sqrt"
          },
          "legend": null
        },
        "order": {
          "field": "value",
          "type": "quantitative",
          "sort": "ascending"
        },
        "tooltip": [
          {
            "field": "district",
            "type": "nominal",
            "title": "District"
          },
          {
            "field": "state",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "total_crimes",
            "type": "quantitative",
            "title": "Total crimes",
            "format": ","
          },
          {
            "field": "total_property",
            "type": "quantitative",
            "title": "Property",
            "format": ","
          },
          {
            "field": "total_assault",
            "type": "quantitative",
            "title": "Assault",
            "format": ","
          }
        ]
      }
    },
    {
      "data": {
        "url": "data/district_totals.csv"
      },
      "transform": [
        {
          "calculate": "metric === 'Property only' ? datum.total_property : metric === 'Assault only' ? datum.total_assault : datum.total_crimes",
          "as": "value"
        },
        {
          "window": [
            {
              "op": "rank",
              "as": "rank"
            }
          ],
          "sort": [
            {
              "field": "value",
              "order": "descending"
            }
          ]
        },
        {
          "filter": "datum.rank <= 5"
        }
      ],
      "projection": {
        "type": "mercator",
        "scale": 2800,
        "center": [
          109.5,
          4.0
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 16,
        "dy": -8,
        "fontSize": 10,
        "fontWeight": 600,
        "color": "blue"
      },
      "encoding": {
        "longitude": {
          "field": "lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "lat",
          "type": "quantitative"
        },
        "text": {
          "field": "district",
          "type": "nominal"
        }
      }
    }
  ],
  "padding": {
    "left": 50,
    "right": 10,
    "top": 5,
    "bottom": 10
  }
}
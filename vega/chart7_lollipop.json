{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "config": {
    "view": {"stroke": null},
    "font": "Inter",
    "axis": {
      "labelFont": "Inter",
      "titleFont": "Inter",
      "domainColor": "#d4d4d8",
      "tickColor": "#d4d4d8",
      "gridColor": "rgba(0,0,0,0.06)",
      "gridDash": [2, 3]
    }
  },
 
  "data": {"url": "data/district_totals.csv"},
  "transform": [
    {
      "calculate": "toNumber(datum.total_crimes)",
      "as": "total_crimes_n"
    },
    {
      "calculate": "toNumber(datum.total_property)",
      "as": "total_property_n"
    },
    {
      "calculate": "toNumber(datum.total_assault)",
      "as": "total_assault_n"
    },
    {
      "window": [{"op": "rank", "as": "rank"}],
      "sort": [{"field": "total_crimes_n", "order": "descending"}]
    },
    {"filter": "datum.rank <= 15"},
    {
      "calculate": "datum.district + ', ' + datum.state",
      "as": "label"
    },
    {
      "calculate": "datum.total_crimes_n >= 10000 ? format(datum.total_crimes_n / 1000, '.0f') + 'k' : format(datum.total_crimes_n, ',.0f')",
      "as": "label_value"
    }
  ],
  "width": 320,
  "height": 500,
  "padding": {"left": 8, "right": 48, "top": 8, "bottom": 8},
  "layer": [
    {
      "mark": {"type": "rule", "strokeWidth": 2, "opacity": 0.55},
      "encoding": {
        "y": {
          "field": "label",
          "type": "nominal",
          "sort": {"field": "total_crimes_n", "order": "descending"},
          "axis": {
            "title": null,
            "labelFontSize": 9.5,
            "labelLimit": 160,
            "labelPadding": 4,
            "ticks": false,
            "domain": false
          }
        },
        "x": {
          "field": "total_crimes_n",
          "type": "quantitative",
          "scale": {"domainMin": 0, "nice": true},
          "axis": {
            "title": "Total crimes (cumulative)",
            "titleFontSize": 9.5,
            "titlePadding": 8,
            "format": "~s",
            "tickCount": 4,
            "labelFontSize": 9,
            "labelAngle": 0
          }
        },
        "x2": {"datum": 0},
        "color": {"value": "#10b981"}
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 90,
        "stroke": "white",
        "strokeWidth": 1.5
      },
      "encoding": {
        "y": {
          "field": "label",
          "type": "nominal",
          "sort": {"field": "total_crimes_n", "order": "descending"}
        },
        "x": {
          "field": "total_crimes_n",
          "type": "quantitative"
        },
        "color": {"value": "#10b981"},
        "tooltip": [
          {"field": "district", "type": "nominal", "title": "District"},
          {"field": "state", "type": "nominal", "title": "State"},
          {"field": "total_crimes_n", "type": "quantitative", "title": "Total crimes", "format": ","},
          {"field": "total_property_n", "type": "quantitative", "title": "Property crimes", "format": ","},
          {"field": "total_assault_n", "type": "quantitative", "title": "Assault crimes", "format": ","}
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 7,
        "fontSize": 9,
        "fontWeight": 600,
        "baseline": "middle"
      },
      "encoding": {
        "y": {
          "field": "label",
          "type": "nominal",
          "sort": {"field": "total_crimes_n", "order": "descending"}
        },
        "x": {
          "field": "total_crimes_n",
          "type": "quantitative"
        },
        "text": {"field": "label_value", "type": "nominal"}
      }
    }
  ]
}
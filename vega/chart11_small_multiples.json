{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Small multiples: one mini area-line per state. Columns wrap into rows. Vertical scale independent per panel so shapes are comparable.",
  "background": "transparent",
  "data": {"url": "data/state_year_total.csv"},
  "transform": [
    {
      "joinaggregate": [
        {"op": "sum", "field": "crimes", "as": "total_state_crimes"}
      ],
      "groupby": ["state"]
    }
  ],
  "columns": 3,
  "facet": {
    "field": "state",
    "type": "nominal",
    "header": {
      "title": null,
      "labelFontSize": 11,
      "labelFontWeight": 600,
      "labelPadding": 6
    },
    "sort": {"field": "total_state_crimes", "order": "descending"}
  },
  "spec": {
    "width": 150,
    "height": 90,
    "layer": [
      {
        "mark": {
          "type": "area",
          "interpolate": "monotone",
          "opacity": 0.35
        },
        "encoding": {
          "x": {
            "field": "year",
            "type": "ordinal",
            "axis": {
              "title": null,
              "labelAngle": 0,
              "labelFontSize": 8,
              "values": [2016, 2020, 2023],
              "labelPadding": 4
            }
          },
          "y": {
            "field": "crimes",
            "type": "quantitative",
            "axis": {
              "title": null,
              "format": "~s",
              "labelFontSize": 8,
              "tickCount": 3,
              "labelPadding": 4,
              "grid": true
            }
          }
        }
      },
      {
        "mark": {
          "type": "line",
          "interpolate": "monotone",
          "color": "#e05c3a",
          "strokeWidth": 2
        },
        "encoding": {
          "x": {"field": "year", "type": "ordinal"},
          "y": {"field": "crimes", "type": "quantitative"},
          "tooltip": [
            {"field": "state", "type": "nominal", "title": "State"},
            {"field": "year", "type": "ordinal", "title": "Year"},
            {"field": "crimes", "type": "quantitative", "title": "Crimes", "format": ","}
          ]
        }
      }
    ]
  },
  "resolve": {
    "scale": {"y": "independent"}
  }
}
{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Small multiples: one mini area-line per state. Columns wrap into rows. Vertical scale independent per panel so shapes are comparable.",
  "background": "transparent",
  "config": {
    "view": {"stroke": null}, "font": "Inter",
    "axis": {
      "labelFont": "Inter", "titleFont": "Inter",
      "labelColor": "#71717a", "titleColor": "#3f3f46",
      "domainColor": "#e4e4e7", "tickColor": "#e4e4e7",
      "gridColor": "rgba(0,0,0,0.04)"
    }
  },
  "title": {
    "text": "All 14 states at a glance",
    "subtitle": "Sorted by total crime. Vertical scale independent per panel so shapes are comparable.",
    "fontSize": 14, "fontWeight": 600,
    "subtitleFontSize": 10, "subtitleColor": "#71717a",
    "anchor": "start", "offset": 8
  },
  "data": {"url": "data/state_year_total.csv"},
  "columns": 4,
  "facet": {
    "field": "state", "type": "nominal",
    "header": {"title": null, "labelFontSize": 12, "labelFontWeight": 600, "labelPadding": 6, "labelColor": "#3f3f46"},
    "sort": {"field": "crimes", "op": "sum", "order": "descending"}
  },
  "spec": {
    "width": 200, "height": 110,
    "layer": [
      {
        "mark": {"type": "area", "interpolate": "monotone", "color": "#cfe0f5", "opacity": 0.5},
        "encoding": {
          "x": {"field": "year", "type": "ordinal",
                "axis": {"title": null, "labelAngle": 0, "labelFontSize": 9, "values": [2016, 2020, 2023], "labelPadding": 4}},
          "y": {"field": "crimes", "type": "quantitative",
                "axis": {"title": null, "format": "~s", "labelFontSize": 9, "tickCount": 3, "labelPadding": 4}}
        }
      },
      {
        "mark": {"type": "line", "interpolate": "monotone", "color": "#3a7ca5", "strokeWidth": 2},
        "encoding": {
          "x": {"field": "year", "type": "ordinal"},
          "y": {"field": "crimes", "type": "quantitative"},
          "tooltip": [
            {"field": "state", "type": "nominal", "title": "State"},
            {"field": "year", "type": "ordinal", "title": "Year"},
            {"field": "crimes", "type": "quantitative", "title": "Crimes", "format": ","}
          ]
        }
      }
    ]
  },
  "resolve": {"scale": {"y": "independent"}}
}
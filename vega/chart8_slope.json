{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "config": {
    "view": { "stroke": null },
    "font": "Inter",
    "axis": {
      "labelFont": "Inter",
      "titleFont": "Inter",
      "labelColor": "#71717a",
      "titleColor": "#3f3f46",
      "domainColor": "#d4d4d8",
      "tickColor": "#d4d4d8",
      "gridColor": "rgba(0,0,0,0.06)"
    }
  },
  "title": {
    "text": "Crime fell everywhere — the question is how fast.",
    "subtitle": "Index = 100 in 2016 per state. Lower 2023 value = steeper decline.",
    "fontSize": 14,
    "fontWeight": 600,
    "subtitleFontSize": 10,
    "subtitleColor": "#71717a",
    "anchor": "start",
    "offset": 10
  },
  "width": 460,
  "height": 500,
  "data": { "url": "data/slope_data.csv" },
  "transform": [
    {
      "window": [
        { "op": "first_value", "field": "crimes", "as": "v_first" },
        { "op": "last_value",  "field": "crimes", "as": "v_last"  }
      ],
      "groupby": ["state"],
      "sort": [{ "field": "year", "order": "ascending" }],
      "frame": [null, null]
    },
    {
      "calculate": "(datum.crimes / datum.v_first) * 100",
      "as": "index_val"
    },
    {
      "calculate": "(datum.v_last - datum.v_first) / datum.v_first * 100",
      "as": "delta_pct"
    }
  ],
  "layer": [

    {
      "description": "GREY — lines",
      "transform": [
        {
          "filter": "datum.state !== 'Selangor' && datum.state !== 'W.P. Kuala Lumpur' && datum.state !== 'Johor' && datum.state !== 'Pulau Pinang' && datum.state !== 'Sabah' && datum.state !== 'Perlis'"
        }
      ],
      "mark": {
        "type": "line",
        "interpolate": "linear",
        "strokeWidth": 0.9,
        "opacity": 0.3,
        "color": "#BBBBBB"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "axis": {
            "title": null,
            "labelFontSize": 13,
            "labelFontWeight": 600,
            "domain": false,
            "ticks": false,
            "orient": "top",
            "labelPadding": 10
          }
        },
        "y": {
          "field": "index_val",
          "type": "quantitative",
          "scale": { "domain": [20, 105] },
          "axis": {
            "title": "Index (2016 = 100)",
            "titleFontSize": 10,
            "values": [20, 30, 40, 50, 60, 70, 80, 90, 100],
            "grid": true,
            "gridDash": [3, 3],
            "labelFontSize": 9,
            "labelColor": "#a1a1aa",
            "format": ".0f"
          }
        },
        "detail": { "field": "state", "type": "nominal" },
        "tooltip": [
          { "field": "state",     "type": "nominal",      "title": "State"    },
          { "field": "v_first",   "type": "quantitative", "title": "2016",    "format": ","    },
          { "field": "v_last",    "type": "quantitative", "title": "2023",    "format": ","    },
          { "field": "delta_pct", "type": "quantitative", "title": "% change","format": "+.0f" },
          { "field": "index_val", "type": "quantitative", "title": "Index",   "format": ".1f"  }
        ]
      }
    },

    {
      "description": "GREY — points",
      "transform": [
        {
          "filter": "datum.state !== 'Selangor' && datum.state !== 'W.P. Kuala Lumpur' && datum.state !== 'Johor' && datum.state !== 'Pulau Pinang' && datum.state !== 'Sabah' && datum.state !== 'Perlis'"
        }
      ],
      "mark": {
        "type": "circle",
        "size": 30,
        "opacity": 0.3,
        "color": "#BBBBBB"
      },
      "encoding": {
        "x": { "field": "year",      "type": "ordinal"      },
        "y": { "field": "index_val", "type": "quantitative" }
      }
    },

    {
      "description": "MID — lines",
      "transform": [
        {
          "filter": "datum.state === 'Johor' || datum.state === 'Pulau Pinang' || datum.state === 'Sabah' || datum.state === 'Perlis'"
        }
      ],
      "mark": {
        "type": "line",
        "interpolate": "linear",
        "strokeWidth": 1.6,
        "opacity": 0.7,
        "color": "#7B8B99"
      },
      "encoding": {
        "x": { "field": "year", "type": "ordinal" },
        "y": { "field": "index_val", "type": "quantitative" },
        "detail": { "field": "state", "type": "nominal" },
        "tooltip": [
          { "field": "state",     "type": "nominal",      "title": "State"    },
          { "field": "v_first",   "type": "quantitative", "title": "2016",    "format": ","    },
          { "field": "v_last",    "type": "quantitative", "title": "2023",    "format": ","    },
          { "field": "delta_pct", "type": "quantitative", "title": "% change","format": "+.0f" },
          { "field": "index_val", "type": "quantitative", "title": "Index",   "format": ".1f"  }
        ]
      }
    },

    {
      "description": "MID — points",
      "transform": [
        {
          "filter": "datum.state === 'Johor' || datum.state === 'Pulau Pinang' || datum.state === 'Sabah' || datum.state === 'Perlis'"
        }
      ],
      "mark": {
        "type": "circle",
        "size": 45,
        "opacity": 0.75,
        "color": "#7B8B99",
        "stroke": "white",
        "strokeWidth": 1
      },
      "encoding": {
        "x": { "field": "year",      "type": "ordinal"      },
        "y": { "field": "index_val", "type": "quantitative" }
      }
    },

    {
      "description": "MID — right % labels only",
      "transform": [
        {
          "filter": "(datum.state === 'Johor' || datum.state === 'Pulau Pinang' || datum.state === 'Sabah' || datum.state === 'Perlis') && datum.year == 2023"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 10,
        "fontSize": 9,
        "fontWeight": 500,
        "color": "#7B8B99"
      },
      "encoding": {
        "x": { "field": "year",      "type": "ordinal"      },
        "y": { "field": "index_val", "type": "quantitative" },
        "text": { "field": "delta_pct", "type": "quantitative", "format": "+.0f" }
      }
    },

    {
      "description": "KEY — lines",
      "transform": [
        {
          "filter": "datum.state === 'Selangor' || datum.state === 'W.P. Kuala Lumpur'"
        }
      ],
      "mark": {
        "type": "line",
        "interpolate": "linear",
        "strokeWidth": 2.5,
        "opacity": 1,
        "color": "#C0392B"
      },
      "encoding": {
        "x": { "field": "year", "type": "ordinal" },
        "y": { "field": "index_val", "type": "quantitative" },
        "detail": { "field": "state", "type": "nominal" },
        "tooltip": [
          { "field": "state",     "type": "nominal",      "title": "State"    },
          { "field": "v_first",   "type": "quantitative", "title": "2016",    "format": ","    },
          { "field": "v_last",    "type": "quantitative", "title": "2023",    "format": ","    },
          { "field": "delta_pct", "type": "quantitative", "title": "% change","format": "+.0f" },
          { "field": "index_val", "type": "quantitative", "title": "Index",   "format": ".1f"  }
        ]
      }
    },

    {
      "description": "KEY — points",
      "transform": [
        {
          "filter": "datum.state === 'Selangor' || datum.state === 'W.P. Kuala Lumpur'"
        }
      ],
      "mark": {
        "type": "circle",
        "size": 60,
        "opacity": 1,
        "color": "#C0392B",
        "stroke": "white",
        "strokeWidth": 1.2
      },
      "encoding": {
        "x": { "field": "year",      "type": "ordinal"      },
        "y": { "field": "index_val", "type": "quantitative" }
      }
    },

    {
      "description": "KEY — right % label at 2023 endpoint",
      "transform": [
        {
          "filter": "(datum.state === 'Selangor' || datum.state === 'W.P. Kuala Lumpur') && datum.year == 2023"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 10,
        "fontSize": 10,
        "fontWeight": 700,
        "color": "#C0392B"
      },
      "encoding": {
        "x": { "field": "year",      "type": "ordinal"      },
        "y": { "field": "index_val", "type": "quantitative" },
        "text": { "field": "delta_pct", "type": "quantitative", "format": "+.0f" }
      }
    },

    {
      "description": "KEY — state name below % label at 2023 endpoint",
      "transform": [
        {
          "filter": "(datum.state === 'Selangor' || datum.state === 'W.P. Kuala Lumpur') && datum.year == 2023"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 10,
        "dy": 13,
        "fontSize": 9,
        "fontWeight": 400,
        "color": "#C0392B",
        "opacity": 0.7
      },
      "encoding": {
        "x": { "field": "year",     "type": "ordinal" },
        "y": { "field": "index_val","type": "quantitative" },
        "text": { "field": "state", "type": "nominal" }
      }
    }

  ]
}
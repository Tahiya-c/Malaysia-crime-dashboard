{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Slope chart 2016\u20132023. Top 3 states highlighted in red. Bracket annotation shows Selangor\u2013Johor gap.",
  "background": "transparent",
  "config": {
    "view": {
      "stroke": null
    },
    "font": "Inter",
    "axis": {
      "labelFont": "Inter",
      "titleFont": "Inter",
      "labelColor": "#52525b",
      "titleColor": "#3f3f46",
      "domainColor": "#d4d4d8",
      "tickColor": "#d4d4d8",
      "gridColor": "rgba(128,128,128,0.12)"
    }
  },
  "title": {
    "text": "Every state fell \u2014 but Selangor still leads by far",
    "subtitle": "Selangor, Johor and KL dominate. All three declined 56\u201373% since 2016.",
    "fontSize": 14,
    "fontWeight": 600,
    "subtitleFontSize": 10,
    "subtitleColor": "#71717a",
    "anchor": "start",
    "offset": 8
  },
  "width": 460,
  "height": 480,
  "data": {
    "url": "data/slope_data.csv"
  },
  "transform": [
    {
      "window": [
        {
          "op": "first_value",
          "field": "crimes",
          "as": "v_first"
        },
        {
          "op": "last_value",
          "field": "crimes",
          "as": "v_last"
        }
      ],
      "groupby": [
        "state"
      ],
      "sort": [
        {
          "field": "year",
          "order": "ascending"
        }
      ],
      "frame": [
        null,
        null
      ]
    },
    {
      "calculate": "(datum.v_last - datum.v_first) / datum.v_first * 100",
      "as": "delta_pct"
    },
    {
      "calculate": "datum.year == 2016 || datum.year == 2023 ? datum.year : null",
      "as": "yr_check"
    },
    {
      "filter": "datum.year == 2016 || datum.year == 2023"
    }
  ],
  "layer": [
    {
      "description": "Muted background lines",
      "transform": [
        {
          "filter": "datum.state !== 'Selangor' && datum.state !== 'Johor' && datum.state !== 'Kuala Lumpur'"
        }
      ],
      "mark": {
        "type": "line",
        "interpolate": "linear",
        "strokeWidth": 1.2,
        "opacity": 0.2,
        "color": "#A1A1AA"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "axis": {
            "title": null,
            "labelFontSize": 12,
            "labelFontWeight": 600,
            "domain": false,
            "ticks": false,
            "orient": "top",
            "labelPadding": 8
          }
        },
        "y": {
          "field": "crimes",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              33000
            ]
          },
          "axis": {
            "title": "Total crimes",
            "format": "~s",
            "grid": true,
            "tickCount": 8,
            "labelFontSize": 9,
            "labelColor": "#a1a1aa"
          }
        },
        "detail": {
          "field": "state"
        }
      }
    },
    {
      "description": "Muted background circles",
      "transform": [
        {
          "filter": "datum.state !== 'Selangor' && datum.state !== 'Johor' && datum.state !== 'Kuala Lumpur'"
        }
      ],
      "mark": {
        "type": "circle",
        "size": 30,
        "opacity": 0.25,
        "color": "#A1A1AA"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "y": {
          "field": "crimes",
          "type": "quantitative"
        }
      }
    },
    {
      "description": "Others label for grey lines",
      "data": {
        "values": [
          {
            "yr": "2016",
            "y": 7440
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "right",
        "dx": -10,
        "fontSize": 10,
        "fontWeight": 500,
        "color": "#a1a1aa",
        "fontStyle": "italic"
      },
      "encoding": {
        "x": {
          "field": "yr",
          "type": "ordinal"
        },
        "y": {
          "field": "y",
          "type": "quantitative"
        },
        "text": {
          "value": "Others"
        }
      }
    },
    {
      "description": "Bracket line \u2014 gap between Selangor and Johor at 2016",
      "data": {
        "values": [
          {
            "yr": "2016",
            "lo": 12941,
            "hi": 31223
          },
          {
            "yr": "2023",
            "lo": 5330,
            "hi": 13739
          }
        ]
      },
      "mark": {
        "type": "rule",
        "color": "#C0392B",
        "strokeWidth": 1,
        "strokeDash": [
          3,
          3
        ],
        "opacity": 0.5
      },
      "encoding": {
        "x": {
          "field": "yr",
          "type": "ordinal"
        },
        "y": {
          "field": "lo",
          "type": "quantitative"
        },
        "y2": {
          "field": "hi"
        }
      }
    },
    {
      "description": "Gap label 2016",
      "data": {
        "values": [
          {
            "yr": "2016",
            "mid": 22082,
            "label": "gap: 18,282"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 8,
        "fontSize": 8.5,
        "color": "#C0392B",
        "opacity": 0.7,
        "fontStyle": "italic"
      },
      "encoding": {
        "x": {
          "field": "yr",
          "type": "ordinal"
        },
        "y": {
          "field": "mid",
          "type": "quantitative"
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    },
    {
      "description": "Gap label 2023",
      "data": {
        "values": [
          {
            "yr": "2023",
            "mid": 9534,
            "label": "gap: 8,409"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 8,
        "fontSize": 8.5,
        "color": "#C0392B",
        "opacity": 0.7,
        "fontStyle": "italic"
      },
      "encoding": {
        "x": {
          "field": "yr",
          "type": "ordinal"
        },
        "y": {
          "field": "mid",
          "type": "quantitative"
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    },
    {
      "description": "Key lines \u2014 top 3 states",
      "transform": [
        {
          "filter": "datum.state === 'Selangor' || datum.state === 'Johor' || datum.state === 'Kuala Lumpur'"
        }
      ],
      "mark": {
        "type": "line",
        "interpolate": "linear",
        "strokeWidth": 2.8,
        "color": "#C0392B"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "y": {
          "field": "crimes",
          "type": "quantitative"
        },
        "detail": {
          "field": "state"
        },
        "tooltip": [
          {
            "field": "state",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "v_first",
            "type": "quantitative",
            "title": "2016",
            "format": ","
          },
          {
            "field": "v_last",
            "type": "quantitative",
            "title": "2023",
            "format": ","
          },
          {
            "field": "delta_pct",
            "type": "quantitative",
            "title": "Change",
            "format": "+.1f"
          }
        ]
      }
    },
    {
      "description": "Key circles",
      "transform": [
        {
          "filter": "datum.state === 'Selangor' || datum.state === 'Johor' || datum.state === 'Kuala Lumpur'"
        }
      ],
      "mark": {
        "type": "circle",
        "size": 60,
        "color": "#C0392B",
        "stroke": "white",
        "strokeWidth": 1.2
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "y": {
          "field": "crimes",
          "type": "quantitative"
        }
      }
    },
    {
      "description": "State name labels left of 2016",
      "transform": [
        {
          "filter": "(datum.state === 'Selangor' || datum.state === 'Johor' || datum.state === 'Kuala Lumpur') && datum.year == 2016"
        }
      ],
      "mark": {
        "type": "text",
        "align": "right",
        "dx": -10,
        "fontSize": 10,
        "fontWeight": 600,
        "color": "#C0392B"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "y": {
          "field": "crimes",
          "type": "quantitative"
        },
        "text": {
          "field": "state",
          "type": "nominal"
        },
        "dy": {
          "condition": {
            "test": "datum.state === 'Kuala Lumpur'",
            "value": -8
          },
          "value": 0
        }
      }
    },
    {
      "description": "% decline labels right of 2023",
      "transform": [
        {
          "filter": "(datum.state === 'Selangor' || datum.state === 'Johor' || datum.state === 'Kuala Lumpur') && datum.year == 2023"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 10,
        "fontSize": 10.5,
        "fontWeight": 700,
        "color": "#C0392B"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "y": {
          "field": "crimes",
          "type": "quantitative"
        },
        "text": {
          "field": "delta_pct",
          "type": "quantitative",
          "format": "+.0f"
        },
        "dy": {
          "condition": {
            "test": "datum.state === 'Kuala Lumpur'",
            "value": 8
          },
          "value": -2
        }
      }
    }
  ]
}
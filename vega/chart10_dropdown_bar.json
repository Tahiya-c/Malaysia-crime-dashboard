{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Per-state yearly bar chart. Single teal colour. Mean reference line. Value labels on bars.",
  "background": "transparent",
  "config": {
    "view": {
      "stroke": null
    },
    "font": "Inter",
    "axis": {
      "labelFont": "Inter",
      "titleFont": "Inter",
      "labelColor": "#52525b",
      "titleColor": "#3f3f46",
      "domainColor": "#d4d4d8",
      "tickColor": "#d4d4d8",
      "gridColor": "rgba(128,128,128,0.1)"
    }
  },
  "title": {
    "text": "Explore each state's trend",
    "subtitle": "Select a state to explore in detail \u00b7 mirrors the small multiples on the right",
    "fontSize": 14,
    "fontWeight": 600,
    "subtitleFontSize": 10,
    "subtitleColor": "#71717a",
    "anchor": "start",
    "offset": 8
  },
  "width": 460,
  "height": 500,
  "params": [
    {
      "name": "state_select",
      "value": "Selangor",
      "bind": {
        "input": "select",
        "options": [
          "Johor",
          "Kedah",
          "Kelantan",
          "Kuala Lumpur",
          "Melaka",
          "Negeri Sembilan",
          "Pahang",
          "Penang",
          "Perak",
          "Perlis",
          "Sabah",
          "Sarawak",
          "Selangor",
          "Terengganu"
        ],
        "name": "State:  "
      }
    }
  ],
  "data": {
    "url": "data/state_year_total.csv"
  },
  "transform": [
    {
      "filter": "datum.state == state_select"
    },
    {
      "joinaggregate": [
        {
          "op": "mean",
          "field": "crimes",
          "as": "state_mean"
        }
      ]
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "bar",
        "color": "#0e7490",
        "cornerRadiusTopLeft": 4,
        "cornerRadiusTopRight": 4
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "axis": {
            "title": null,
            "labelAngle": 0
          }
        },
        "y": {
          "field": "crimes",
          "type": "quantitative",
          "axis": {
            "title": "Total crimes",
            "format": "~s",
            "tickCount": 5
          }
        },
        "tooltip": [
          {
            "field": "state",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "year",
            "type": "ordinal",
            "title": "Year"
          },
          {
            "field": "crimes",
            "type": "quantitative",
            "title": "Crimes",
            "format": ","
          }
        ]
      }
    },
    {
      "mark": {
        "type": "rule",
        "color": "#D55E00",
        "strokeWidth": 1.3,
        "strokeDash": [
          5,
          4
        ]
      },
      "encoding": {
        "y": {
          "field": "state_mean",
          "type": "quantitative"
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "right",
        "dx": -4,
        "dy": -6,
        "color": "#D55E00",
        "fontSize": 9,
        "fontStyle": "italic"
      },
      "encoding": {
        "x": {
          "datum": "2023"
        },
        "y": {
          "field": "state_mean",
          "type": "quantitative"
        },
        "text": {
          "value": "8-yr mean"
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "dy": -8,
        "fontSize": 9,
        "color": "#52525b",
        "fontWeight": 600
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "y": {
          "field": "crimes",
          "type": "quantitative"
        },
        "text": {
          "field": "crimes",
          "type": "quantitative",
          "format": ",.0f"
        }
      }
    }
  ]
}
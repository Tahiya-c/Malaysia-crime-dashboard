{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Dot plot: each state's 2023 crime rate per 100k vs national average. Shows which states are above/below average after controlling for population.",
  "background": "transparent",
  "config": {
    "view": {
      "stroke": null
    },
    "font": "Inter",
    "axis": {
      "labelFont": "Inter",
      "titleFont": "Inter",
      "labelColor": "#71717a",
      "titleColor": "#3f3f46",
      "domainColor": "#d4d4d8",
      "tickColor": "#d4d4d8",
      "gridColor": "rgba(128,128,128,0.12)"
    }
  },
  "title": {
    "text": "Which states exceed the national crime rate?",
    "subtitle": "Crimes per 100,000 population in 2023. Dashed line = 14-state average (369 per 100k).",
    "fontSize": 14,
    "fontWeight": 600,
    "subtitleFontSize": 10,
    "subtitleColor": "#71717a",
    "anchor": "start",
    "offset": 8
  },
  "width": "container",
  "height": 380,
  "data": {
    "url": "data/state_rate_2023.csv"
  },
  "layer": [
    {
      "description": "National average reference line",
      "mark": {
        "type": "rule",
        "color": "#71717a",
        "strokeDash": [
          4,
          3
        ],
        "strokeWidth": 1.2,
        "opacity": 0.7
      },
      "encoding": {
        "x": {
          "datum": 369.1,
          "type": "quantitative"
        }
      }
    },
    {
      "description": "Horizontal line from axis to dot",
      "mark": {
        "type": "rule",
        "strokeWidth": 1.5,
        "opacity": 0.4
      },
      "encoding": {
        "y": {
          "field": "state",
          "type": "nominal",
          "sort": {
            "field": "rate",
            "order": "descending"
          },
          "axis": {
            "title": null,
            "labelFontSize": 11,
            "labelPadding": 6,
            "ticks": false,
            "domain": false
          }
        },
        "x": {
          "field": "rate",
          "type": "quantitative",
          "axis": {
            "title": "Crimes per 100,000 population",
            "tickCount": 6,
            "grid": true,
            "labelFontSize": 10
          },
          "scale": {
            "domain": [
              0,
              750
            ]
          }
        },
        "x2": {
          "datum": 369.1
        },
        "color": {
          "field": "above_avg",
          "type": "nominal",
          "scale": {
            "domain": [
              "Above average",
              "Below average"
            ],
            "range": [
              "#e05c3a",
              "#4a90d9"
            ]
          },
          "legend": null
        }
      }
    },
    {
      "description": "State dot",
      "mark": {
        "type": "circle",
        "size": 90,
        "stroke": "white",
        "strokeWidth": 1.2
      },
      "encoding": {
        "y": {
          "field": "state",
          "type": "nominal",
          "sort": {
            "field": "rate",
            "order": "descending"
          }
        },
        "x": {
          "field": "rate",
          "type": "quantitative"
        },
        "color": {
          "field": "above_avg",
          "type": "nominal",
          "scale": {
            "domain": [
              "Above average",
              "Below average"
            ],
            "range": [
              "#e05c3a",
              "#4a90d9"
            ]
          },
          "legend": {
            "title": null,
            "orient": "bottom",
            "labelFontSize": 10,
            "symbolSize": 80,
            "offset": 6
          }
        },
        "tooltip": [
          {
            "field": "state",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "rate",
            "type": "quantitative",
            "title": "Per 100k pop",
            "format": ",.0f"
          },
          {
            "field": "deviation",
            "type": "quantitative",
            "title": "vs avg",
            "format": "+.0f"
          },
          {
            "field": "above_avg",
            "type": "nominal",
            "title": "Status"
          }
        ]
      }
    },
    {
      "description": "Labels right of dot for above-average states",
      "transform": [
        {
          "window": [
            {
              "op": "rank",
              "as": "rank_top"
            }
          ],
          "sort": [
            {
              "field": "rate",
              "order": "descending"
            }
          ]
        },
        {
          "filter": "datum.above_avg === 'Above average' && datum.rank_top <= 3"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 10,
        "fontSize": 9.5,
        "fontWeight": 600,
        "color": "#e05c3a"
      },
      "encoding": {
        "y": {
          "field": "state",
          "type": "nominal",
          "sort": {
            "field": "rate",
            "order": "descending"
          }
        },
        "x": {
          "field": "rate",
          "type": "quantitative"
        },
        "text": {
          "field": "rate",
          "type": "quantitative",
          "format": ",.0f"
        }
      }
    },
    {
      "description": "Labels left of dot for bottom 2 below-average states",
      "transform": [
        {
          "window": [
            {
              "op": "rank",
              "as": "rank_bot"
            }
          ],
          "sort": [
            {
              "field": "rate",
              "order": "ascending"
            }
          ]
        },
        {
          "filter": "datum.above_avg === 'Below average' && datum.rank_bot <= 2"
        }
      ],
      "mark": {
        "type": "text",
        "align": "right",
        "dx": -10,
        "fontSize": 9.5,
        "fontWeight": 600,
        "color": "#4a90d9"
      },
      "encoding": {
        "y": {
          "field": "state",
          "type": "nominal",
          "sort": {
            "field": "rate",
            "order": "descending"
          }
        },
        "x": {
          "field": "rate",
          "type": "quantitative"
        },
        "text": {
          "field": "rate",
          "type": "quantitative",
          "format": ",.0f"
        }
      }
    }
  ]
}